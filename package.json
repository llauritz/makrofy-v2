    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0"
